// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum StatusAssignment {
  DRAFT
  PUBLISH
  START
  FINISH
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(100)
  position  String   @db.VarChar(100)
  divisi    String   @db.VarChar(100)
  role      Role     @default(USER)
  token     String?  @unique @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicsCreated Topic[] @relation("TopicCreatedByUser")
  topicsUpdated Topic[] @relation("TopicUpdatedByUser")

  materialCreated Material[] @relation("MaterialCreatedByUser")
  materialUpdated Material[] @relation("MaterialUpdatedByUser")

  assignmentCreated Assignment[] @relation("AssignmentCreatedByUser")
  assignmentUpdated Assignment[] @relation("AssignmentUpdatedByUser")

  assignments Assignment[]

  @@map("users")
}

model Topic {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  description String   @db.VarChar(500)
  createdBy   Int
  updatedBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdUser User         @relation("TopicCreatedByUser", fields: [createdBy], references: [id])
  updatedUser User?        @relation("TopicUpdatedByUser", fields: [updatedBy], references: [id])
  materials   Material[]
  assignment  Assignment[]

  @@map("topics")
}

model Material {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  description String   @db.VarChar(500)
  topicId     Int
  fileUrl     String   @db.VarChar(500)
  createdBy   Int
  updatedBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic       Topic        @relation(fields: [topicId], references: [id])
  createdUser User         @relation("MaterialCreatedByUser", fields: [createdBy], references: [id])
  updatedUser User?        @relation("MaterialUpdatedByUser", fields: [updatedBy], references: [id])
  assignment  Assignment[]

  @@map("materials")
}

model Assignment {
  id             Int              @id @unique @default(autoincrement())
  topicId        Int
  materialId     Int
  userId         Int
  trainingDate   DateTime
  status         StatusAssignment @default(DRAFT)
  startTime      DateTime
  endTime        DateTime
  maxParticipant Int
  classRoomLink  String           @db.VarChar(500)
  createdBy      Int
  updatedBy      Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  createdUser User  @relation("AssignmentCreatedByUser", fields: [createdBy], references: [id])
  updatedUser User? @relation("AssignmentUpdatedByUser", fields: [updatedBy], references: [id])

  trainerUser User     @relation(fields: [userId], references: [id])
  topic       Topic    @relation(fields: [topicId], references: [id])
  material    Material @relation(fields: [materialId], references: [id])

  @@map("assignments")
}
